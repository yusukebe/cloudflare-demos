{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "cf-demos-gateway",
  "main": "src/gateway.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "services": [
    {
      "binding": "BACKEND",
      "service": "cf-demos-backend",
    },
  ],
}
