{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "cf-demos-vectorize",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "ai": {
    "binding": "AI",
    "remote": true,
  },
  "vectorize": [
    {
      "binding": "INDEX",
      "index_name": "cf-demos-notes",
      "remote": true,
    },
  ],
}
