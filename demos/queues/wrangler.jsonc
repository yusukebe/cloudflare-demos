{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "cf-demos-queues",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "queues": {
    "producers": [
      {
        "binding": "QUEUE",
        "queue": "cf-demos-queue",
      },
    ],
    "consumers": [
      {
        "queue": "cf-demos-queue",
        "max_batch_timeout": 1,
      },
    ],
  },
}
